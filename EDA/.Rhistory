# load data
df <- read_csv("player_stats.csv") %>%
clean_names()
# libraries
library(tidyverse)
library(janitor)
library(ggplot2)
library(dplyr)
library(readr)
library(forcats)
library(skimr)
# load data
df <- read_csv("/Users/xuzibo/Desktop/Math244/final/Math-244-final-project-Team-GG/data/player_stats.csv") %>%
clean_names()
# preview
# glimpse(df)
# Data cleaning
df <- df %>%
mutate(
# outcome variable
xg_diff = goals - xg,
efficiency_per90 = goals_per90 - xg_per90,
# non-penalty
np_xg_diff = goals_pens - npxg,
np_efficiency_per90 = (goals_pens / minutes_90s) - (npxg / minutes_90s),
age_years = as.integer(str_extract(age, "^[0-9]+")),
is_overperformer = if_else(xg_diff > 0, 1L, 0L),
position = factor(position, levels = c("FW", "MF", "DF", "GK"))
) %>%
filter(minutes_90s >= 1) %>%# drop players with minimal playing time
drop_na(xg, goals, position, age_years)
# Distribution of Efficiency
ggplot(df, aes(x = xg_diff)) +
geom_histogram(bins = 30, fill = "steelblue", alpha = 0.7) +
geom_vline(xintercept = 0, linetype = "dashed") +
labs(
title = "Distribution of Scoring Efficiency (Goals - xG)",
x = "xG Difference",
y = "Number of Players"
) +
theme_minimal()
# Efficiency by Position (BOXPLOT)
ggplot(df, aes(x = position, y = xg_diff, fill = position)) +
geom_boxplot() +
labs(
title = "Scoring Efficiency by Position",
x = "Position",
y = "Goals - xG"
) +
theme_minimal()
# Total Goals vs Tota xG by Position Plot
df |>
group_by(position) |>
summarise(Total_Goals = sum(goals),
Total_xG    = sum(xg, na.rm = TRUE)) |>
pivot_longer(cols = c(Total_Goals, Total_xG),
names_to = "metric", values_to = "value") |>
ggplot(aes(x = position, y = value, fill = metric)) +
geom_col(position = "dodge", width = 0.6) +
scale_fill_manual(values = c("Total_Goals" = "#3b82f6",
"Total_xG"    = "#94a3b8")) +
labs(title = "Total Goals vs. Total xG by Position",
x = NULL, y = "Total", fill = NULL) +
theme_minimal()
#Age vs Efficiency
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
theme_minimal()
# Top 5 over and under performers plot
top5_over  <- df |> slice_max(order_by = xg_diff, n = 5) |> mutate(group = "Overperformer")
top5_under <- df |> slice_min(order_by = xg_diff, n = 5) |> mutate(group = "Underperformer")
bind_rows(top5_over, top5_under) |>
mutate(
label  = paste0(player, " (", team, ")"),
label  = fct_reorder(label, xg_diff)
) |>
ggplot(aes(x = xg_diff, y = label, fill = group)) +
geom_col(width = 0.65) +
geom_vline(xintercept = 0, linewidth = 0.8, color = "grey30") +
geom_text(aes(label = round(xg_diff, 1),
hjust = if_else(xg_diff > 0, -0.2, 1.2)),
size = 3.5, fontface = "bold") +
scale_fill_manual(values = c("Overperformer" = "#22c55e",
"Underperformer" = "#ef4444")) +
labs(
title    = "Top 5 Over- and Underperformers",
subtitle = "xg_diff = goals − expected goals  |  ≥1 full 90-min played",
x        = "xg_diff (goals − xG)",
y        = NULL,
fill     = NULL
) +
theme_minimal(base_size = 13) +
theme(
legend.position  = "top",
plot.title       = element_text(face = "bold"),
panel.grid.major.y = element_blank()
)
# Expected Goals vs Actual Goals Plot
df |>
filter(!is.na(xg)) |>
ggplot(aes(x = xg, y = goals, color = position)) +
geom_abline(slope = 1, intercept = 0,
linetype = "dashed", color = "grey40", linewidth = 0.9) +
geom_point(aes(size = minutes_90s), alpha = 0.6) +
geom_text(
data = . %>% filter(abs(goals - xg) > 1.5),
aes(label = player),
size = 3, vjust = -0.7, show.legend = FALSE
) +
scale_color_manual(values = c(
"FW" = "#ef4444", "MF" = "#3b82f6",
"DF" = "#22c55e", "GK" = "#f59e0b"
)) +
scale_size_continuous(range = c(1.5, 6), guide = "none") +
labs(
title    = "Expected Goals vs. Actual Goals",
subtitle = "Points above the dashed line scored more than their xG predicted",
x = "Expected Goals (xG)", y = "Actual Goals",
color = "Position"
) +
theme_minimal(base_size = 13) +
theme(plot.title = element_text(face = "bold"))
# Top 10 Most Efficient Players
top10 <- df %>%
arrange(desc(xg_diff)) %>%
slice_head(n = 10)
ggplot(top10, aes(x = reorder(player, xg_diff), y = xg_diff)) +
geom_col(fill = "darkgreen") +
coord_flip() +
labs(
title = "Top 10 Most Efficient Players",
x = "Player",
y = "Goals - xG"
) +
theme_minimal()
# Team-Level Efficiency
team_eff <- df %>%
group_by(team) %>%
summarize(avg_eff = mean(xg_diff, na.rm = TRUE)) %>%
arrange(desc(avg_eff)) %>%
slice_head(n = 10)
ggplot(team_eff, aes(x = reorder(team, avg_eff), y = avg_eff)) +
geom_col(fill = "purple") +
coord_flip() +
labs(
title = "Top 10 Teams by Average Scoring Efficiency",
x = "Team",
y = "Average Goals - xG"
) +
theme_minimal()
df %>% select(goals, xg, xg_diff, age) %>%
summary()
skim(df)
model <- lm(xg_diff ~ age + position, data = df)
summary(model)
#Age vs Efficiency
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
scale_x_continuous(breaks = seq(min(df$age), max(df$age), by = 2)) +
theme_minimal()
#Age vs Efficiency
df$age <- as.numeric(as.character(df$age))
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
scale_x_continuous(breaks = seq(min(df$age), max(df$age), by = 2)) +
theme_minimal()
#Age vs Efficiency
df$age <- as.numeric(as.character(df$age))
summary(df$age)
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
scale_x_continuous(breaks = seq(min(df$age), max(df$age), by = 2)) +
theme_minimal()
#Age vs Efficiency
df$age <- as.numeric(as.character(df$age))
summary(df$age)
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
#scale_x_continuous(breaks = seq(min(df$age), max(df$age), by = 2)) +
theme_minimal()
#Age vs Efficiency
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
scale_x_continuous(
breaks = seq(floor(min(df2$age)), ceiling(max(df2$age)), by = 2)
) +  theme_minimal()
#Age vs Efficiency
ggplot(df, aes(x = age, y = xg_diff)) +
geom_point(alpha = 0.5) +
geom_smooth(method = "lm", se = FALSE, color = "red") +
labs(
title = "Age vs Scoring Efficiency",
x = "Age",
y = "Goals - xG"
) +
theme_minimal()
